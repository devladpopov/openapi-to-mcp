{
  "name": "openapi-to-mcp",
  "version": "0.2.0",
  "description": "Generate MCP servers from OpenAPI 3.x specifications. One command, working server.",
  "type": "module",
  "bin": {
    "openapi-to-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node -e \"require('fs').copyFileSync('dist/index.d.ts','dist/index.d.cts')\"",
    "build:check": "tsc --noEmit",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "bun test",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openapi",
    "mcp",
    "model-context-protocol",
    "code-generator",
    "codegen",
    "ai",
    "claude",
    "cursor",
    "chatgpt",
    "typescript",
    "api",
    "oauth2",
    "rest",
    "swagger"
  ],
  "author": "Vlad Popov <devladpopov@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/devladpopov/openapi-to-mcp#readme",
  "bugs": {
    "url": "https://github.com/devladpopov/openapi-to-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devladpopov/openapi-to-mcp.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
